# Sketch — Environment Configuration
#
# Copy this file to .env and edit as needed.
# LLM credentials, Slack tokens, and WhatsApp pairing are configured
# through the web UI during onboarding — not in this file.

# Database
# Supported: sqlite (default), postgres
DB_TYPE=sqlite
SQLITE_PATH=./data/sketch.db
# DATABASE_URL=postgres://sketch:sketch@localhost:5432/sketch

# LiteLLM proxy port (used when LiteLLM is selected as LLM provider)
# LITELLM_PORT=4000

# Server
# BASE_URL=https://sketch.yourcompany.com  # Used for email verification links; auto-detected from request headers if unset
DATA_DIR=./data
PORT=3000
LOG_LEVEL=info          # debug | info | warn | error
